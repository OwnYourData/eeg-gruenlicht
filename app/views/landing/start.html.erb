<% content_for :title, "Regionale Energiegemeinschaft in Bad Vöslau" %>
<% content_for :meta_description, "EEG Grünes Licht Bad Vöslau: regionale Energiegemeinschaft mit 10 ct/kWh netto, reduzierten Netzentgelten beim Bezug innerhalb der EEG, keiner Mitgliedsgebühr und monatlicher Abrechnung." %>
<% content_for :canonical_path, root_path %>
<% content_for :og_type, "website" %>

<% content_for :structured_data do %>
  <script type="application/ld+json">
    <%= raw JSON.pretty_generate({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "EEG Grünes Licht Bad Vöslau",
      "url": canonical_url,
      "description": seo_description,
      "about": {
        "@type": "Organization",
        "name": "EEG Grünes Licht Bad Vöslau"
      }
    }) %>
  </script>
<% end %>

<section class="mx-auto max-w-6xl px-6 py-16 sm:py-20 lg:py-24">
    <div class="grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
        <div class="max-w-2xl">
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.22em] text-green-700">
                Erneuerbare-Energie-Gemeinschaft
            </p>

            <h1 class="text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
                Lokal erzeugten Strom gemeinsam nutzen.
            </h1>

            <p class="mt-6 text-lg leading-8 text-slate-600">
                Die Erneuerbare-Energie-Gemeinschaft Grünes-Licht-Bad-Vöslau ermöglicht die gemeinsame Nutzung regional erzeugter Energie.
                Unser Verein wurde 2025 gegründet und ist seit dem 1. Quartal 2026 operativ.
            </p>

            <div class="mt-8 flex flex-wrap gap-4">
                <%= link_to "Jetzt mitmachen", "#kontakt",
                    class: "inline-flex items-center rounded-xl bg-green-700 px-5 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-green-800" %>

                <%= link_to "So funktioniert’s", "#funktion",
                    class: "inline-flex items-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-medium text-slate-900 transition hover:bg-slate-50" %>
            </div>
        </div>

<div class="rounded-3xl border border-slate-200 bg-slate-50 p-7">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
        Aktueller Stand
    </p>

    <div class="mt-6">
        <p class="text-sm text-slate-500">Organisation</p>
        <p class="mt-1 text-base font-semibold text-slate-900">
            Regionale EEG <span class="text-slate-500">(RC107602)</span>
        </p>
        <p class="text-base font-semibold text-slate-900">
            <%= ENV['ANZAHL_EINSPEISER']  || "3" %> Einspeiser · <%= ENV['ANZAHL_VERBRAUCHER']  || "5" %> Verbraucher
        </p>
    </div>

    <div class="mt-5">
        <p class="text-sm text-slate-500">Konditionen</p>

        <div class="mt-1 space-y-1">
            <p class="text-base font-semibold text-slate-900">
                10 ct/kWh netto
                <span class="ml-1 text-sm font-normal text-slate-500">
                    (für Einspeiser/Abnehmer gleich)
                </span>
            </p>
            <p class="text-base font-semibold text-slate-900">
                reduzierte Netzentgelte
                <span class="ml-1 text-sm font-normal text-slate-500">
                    (beim Bezug aus EEG)
                </span>
            </p>                    
        </div>
    </div>

    <div class="mt-6 space-y-3 text-sm text-slate-700">
        <div class="flex gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-green-600"></span>
            <p>Keine Eintritts- oder Mitgliedsgebühr</p>
        </div>

        <div class="flex gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-green-600"></span>
            <p>Monatliche Abrechnung</p>
        </div>

        <div class="flex gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-green-600"></span>
            <p>Ein- und Austritt jederzeit möglich</p>
        </div>
    </div>
</div>

    </div>
</section>

<section class="border-y border-slate-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-6 px-6 py-8 md:grid-cols-3">
        <div>
            <p class="text-sm font-semibold text-green-700">Regional organisiert</p>
            <p class="mt-1 font-medium text-slate-900">Lokale Energie für eine lokale Gemeinschaft</p>
        </div>

        <div>
            <p class="text-sm font-semibold text-green-700">Ökologisch</p>
