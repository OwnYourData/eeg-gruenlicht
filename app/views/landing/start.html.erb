            <p class="mt-1 font-medium text-slate-900">Klare Abläufe für Teilnahme und Abrechnung</p>
        </div>
    </div>
</section>

<section id="funktion" class="bg-green-50">
    <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
        <div class="max-w-3xl">
