<% content_for :title, "Strompreise" %>
<% content_for :meta_description, "Aktuelle und historische Einspeise- und Bezugspreise der EEG-GrünLicht-Energiegemeinschaften." %>
<% content_for :canonical_path, preise_path %>

<%
    eegs = [
        {
            id: "bad-voeslau",
            name: "EEG Grünes Licht Bad Vöslau",
            prices: [
                {
                    period: "ab 1. Juli 2026",
                    feed_in_price: "11 ct/kWh",
                    consumption_price: "11 ct/kWh",
                    current: true
                },
                {
                    period: "1. März bis 30. Juni 2026",
                    feed_in_price: "12 ct/kWh",
                    consumption_price: "12 ct/kWh",
                    current: false
                }
            ]
        },
        {
            id: "flugfeld",
            name: "EEG Grünes Licht Bad Vöslau-Flugfeld",
            prices: [
                {
                    period: "ab 1. Juli 2026",
                    feed_in_price: "11 ct/kWh",
                    consumption_price: "11 ct/kWh",
                    current: true
                },
                {
                    period: "1. Mai bis 30. Juni 2026",
                    feed_in_price: "12 ct/kWh",
                    consumption_price: "12 ct/kWh",
                    current: false
                }
            ]
        },
        {
            id: "voeslau-sooss",
            name: "EEG Grünes Licht Bad Vöslau/Sooß",
            prices: [
                {
                    period: "ab 1. Juli 2026",
                    feed_in_price: "11 ct/kWh",
                    consumption_price: "11 ct/kWh",
                    current: true
                }
            ]
        }
    ]
%>

<section class="bg-white">
    <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
        <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-green-700">
                Preisübersicht
            </p>

            <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
                Aktuelle und historische Strompreise
            </h1>

            <p class="mt-5 text-lg leading-8 text-slate-600">
                Die drei Energiegemeinschaften werden als rechtlich und organisatorisch
                eigenständige Vereine geführt. Die Preisgestaltung wird daher von jeder EEG
                selbst beschlossen. Wir bemühen uns jedoch, die Konditionen in allen drei Energiegemeinschaften möglichst einheitlich zu gestalten.
            </p>
        </div>

        <div class="mt-12 space-y-10">
            <% eegs.each do |eeg| %>
                <section
                    id="preise-<%= eeg[:id] %>"
                    class="scroll-mt-28 overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm"
                >
                    <div class="border-b border-slate-200 bg-slate-50 px-6 py-5 sm:px-8">
                        <p class="text-sm font-medium text-green-700">
                            Eigenständige Energiegemeinschaft
                        </p>

                        <h2 class="mt-1 text-xl font-semibold text-slate-900">
                            <%= eeg[:name] %>
                        </h2>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full min-w-[640px] text-left">
                            <thead class="border-b border-slate-200 bg-white">
                                <tr>
                                    <th class="px-6 py-4 text-sm font-semibold text-slate-900 sm:px-8">
                                        Gültigkeitszeitraum
                                    </th>

                                    <th class="px-6 py-4 text-sm font-semibold text-slate-900">
                                        Einspeisepreis
                                    </th>

                                    <th class="px-6 py-4 text-sm font-semibold text-slate-900">
                                        Bezugspreis
                                    </th>

                                    <th class="px-6 py-4 text-sm font-semibold text-slate-900 sm:pr-8">
                                        Status
                                    </th>
                                </tr>
                            </thead>

                            <tbody class="divide-y divide-slate-200">
                                <% eeg[:prices].each do |price| %>
                                    <tr class="<%= price[:current] ? "bg-green-50" : "bg-white" %>">
                                        <td class="px-6 py-5 text-sm text-slate-700 sm:px-8">
                                            <%= price[:period] %>
                                        </td>

                                        <td class="px-6 py-5">
                                            <span class="font-semibold text-slate-900">
                                                <%= price[:feed_in_price] %>
                                            </span>
                                            <span class="ml-1 text-sm text-slate-500">
                                                USt-frei
                                            </span>
                                        </td>

                                        <td class="px-6 py-5">
                                            <span class="font-semibold text-slate-900">
                                                <%= price[:consumption_price] %>
                                            </span>
                                            <span class="ml-1 text-sm text-slate-500">
                                                brutto
                                            </span>
                                        </td>

                                        <td class="px-6 py-5 sm:pr-8">
                                            <% if price[:current] %>
                                                <span class="inline-flex rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800">
                                                    Aktuell
                                                </span>
                                            <% else %>
                                                <span class="text-sm text-slate-500">
                                                    Historisch
                                                </span>
                                            <% end %>
                                        </td>
                                    </tr>
                                <% end %>
                            </tbody>
                        </table>
                    </div>
                </section>
            <% end %>
        </div>

        <div class="mt-10 rounded-2xl border border-slate-200 bg-slate-50 px-6 py-5 text-sm leading-7 text-slate-600">
            <p>
                Die angeführten Preise beziehen sich auf die innerhalb der jeweiligen EEG
                eingespeiste beziehungsweise bezogene Energie. Beim Strombezug kommen die
                gesetzlich vorgesehenen reduzierten Netzentgelte für EEG-Strom hinzu.<br>
                Änderungen der Preise werden von der jeweils zuständigen Energiegemeinschaft
                beschlossen und vor ihrem Inkrafttreten bekannt gegeben.
            </p>
        </div>
    </div>
</section>