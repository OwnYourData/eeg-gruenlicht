<%= turbo_frame_tag "kontaktformular" do %>
    <section id="kontakt" class="bg-green-50">
        <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
            <div class="mx-auto max-w-4xl">
                <div class="max-w-2xl">
                    <h2 class="text-3xl font-semibold tracking-tight text-slate-900">
                        Kontakt
                    </h2>

                    <p class="mt-4 text-lg leading-8 text-slate-600">
                        Schreiben Sie uns unverbindlich. Wir unterstützen Interessierte und Mitglieder
                        bei Einstieg, Teilnahme und laufender Abwicklung innerhalb der EEG.
                    </p>
                </div>

                <% if local_assigns[:flash_message].present? %>
                    <div class="mt-6 rounded-2xl border border-green-200 bg-green-100 px-5 py-4 text-sm text-green-900">
                        <%= flash_message %>
                    </div>
                <% end %>

                <% if contact_request.errors.any? %>
                    <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-800">
                        <p class="font-semibold">Bitte prüfen Sie Ihre Eingaben.</p>
                        <ul class="mt-2 list-disc pl-5">
                            <% contact_request.errors.full_messages.each do |msg| %>
                                <li><%= msg %></li>
                            <% end %>
                        </ul>
                    </div>
                <% end %>

                <div class="mt-8 rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
                    <%= form_with model: contact_request,
                                  url: kontakt_path,
                                  method: :post,
                                  class: "space-y-6" do |f| %>

                        <div>
                            <%= f.label :name, "Ihr Name", class: "mb-2 block text-sm font-medium text-slate-700" %>
                            <%= f.text_field :name,
                                required: true,
                                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 shadow-sm outline-none transition focus:border-green-600 focus:ring-2 focus:ring-green-100" %>
                        </div>

                        <div>
                            <%= f.label :email, "Ihre E-Mail", class: "mb-2 block text-sm font-medium text-slate-700" %>
                            <%= f.email_field :email,
                                required: true,
                                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 shadow-sm outline-none transition focus:border-green-600 focus:ring-2 focus:ring-green-100" %>
                        </div>

                        <div>
                            <%= f.label :message, "Ihre Nachricht", class: "mb-2 block text-sm font-medium text-slate-700" %>
                            <%= f.text_area :message,
                                rows: 6,
                                required: true,
                                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 shadow-sm outline-none transition focus:border-green-600 focus:ring-2 focus:ring-green-100" %>
                        </div>

                        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
                            <div class="flex items-start gap-3">
                                <%= f.check_box :privacy_consent,
                                    required: true,
                                    class: "mt-1 h-5 w-5 rounded border-slate-300 text-green-700 focus:ring-green-600" %>

                                <%= f.label :privacy_consent, class: "text-sm leading-6 text-slate-700" do %>
                                    Ich stimme zu, dass die im Formular angegebenen personenbezogenen Daten
                                    zur Bearbeitung meiner Anfrage verarbeitet werden. Die Einwilligung kann
                                    jederzeit mit Wirkung für die Zukunft widerrufen werden.
                                    Es gilt unsere
                                    <%= link_to "Datenschutzerklärung",
                                        datenschutz_path,
                                        data: { turbo_frame: "_top" },
                                        class: "font-medium text-green-700 underline decoration-green-300 underline-offset-2 hover:text-green-800" %>.
                                <% end %>
                            </div>
                        </div>
                        
                        <div class="hidden">
                            <%= f.label :honeypot, "Weiteres Feld" %>
                            <%= f.text_field :honeypot,
                                autocomplete: "off",
                                tabindex: "-1",
                                aria: { hidden: true } %>
                        </div>

                        <div>
                            <%= f.submit "Nachricht senden",
                                class: "inline-flex w-full items-center justify-center rounded-xl bg-green-600 px-5 py-3 text-base font-medium text-white shadow-sm transition hover:bg-green-700" %>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </section>
<% end %>