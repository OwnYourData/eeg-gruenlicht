<%= turbo_frame_tag "kontaktformular" do %>
    <div>
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900">
            Kontaktanfrage
        </h2>

        <p class="mt-3 text-base leading-7 text-slate-600">
            Schreiben Sie uns unverbindlich. Wir unterstützen Interessierte und Mitglieder
            bei Einstieg, Teilnahme und laufender Abwicklung innerhalb der EEG.
        </p>

        <% if local_assigns[:flash_message].present? %>
            <div class="mt-6 rounded-2xl border border-green-200 bg-green-100 px-5 py-4 text-sm text-green-900">
                <%= flash_message %>
            </div>
        <% end %>

        <% if contact_request.errors.any? %>
            <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-800">
                <p class="font-semibold">
                    Bitte prüfen Sie Ihre Eingaben.
                </p>

                <ul class="mt-2 list-disc pl-5">
                    <% contact_request.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                    <% end %>
                </ul>
            </div>
        <% end %>

        <%= form_with model: contact_request,
                      url: kontakt_path,
                      method: :post,
                      html: { novalidate: true },
                      class: "mt-8 space-y-6" do |form| %>

            <div>
                <%= form.label :name,
                    "Ihr Name",
                    class: "mb-2 block text-sm font-medium text-slate-700" %>

                <%= form.text_field :name,
                    autocomplete: "name",
                    class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 shadow-sm outline-none transition focus:border-green-600 focus:ring-2 focus:ring-green-100" %>
            </div>

            <div>
                <%= form.label :email,
                    "Ihre E-Mail",
                    class: "mb-2 block text-sm font-medium text-slate-700" %>

                <%= form.email_field :email,
                    autocomplete: "email",
                    class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 shadow-sm outline-none transition focus:border-green-600 focus:ring-2 focus:ring-green-100" %>
            </div>

            <div>
                <%= form.label :message,
                    "Ihre Nachricht",
                    class: "mb-2 block text-sm font-medium text-slate-700" %>

                <%= form.text_area :message,
                    rows: 6,
                    class: "block w-full resize-y rounded-xl border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 shadow-sm outline-none transition focus:border-green-600 focus:ring-2 focus:ring-green-100" %>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4">
                <div class="flex items-start gap-3">
                    <%= form.check_box :privacy_consent,
                        class: "mt-1 h-5 w-5 shrink-0 rounded border-slate-300 text-green-700 focus:ring-green-600" %>

                    <%= form.label :privacy_consent,
                        class: "text-sm leading-6 text-slate-700" do %>
                        Ich stimme zu, dass die im Formular angegebenen personenbezogenen Daten
                        zur Bearbeitung meiner Anfrage verarbeitet werden. Die Einwilligung kann
                        jederzeit mit Wirkung für die Zukunft widerrufen werden. Es gilt unsere
                        <%= link_to "Datenschutzerklärung",
                            datenschutz_path,
                            data: { turbo_frame: "_top" },
                            class: "font-medium text-green-700 underline decoration-green-300 underline-offset-2 hover:text-green-800" %>.
                    <% end %>
                </div>
            </div>

            <div class="hidden" aria-hidden="true">
                <%= form.label :honeypot, "Weiteres Feld" %>

                <%= form.text_field :honeypot,
                    autocomplete: "off",
                    tabindex: "-1" %>
            </div>

            <div>
                <%= form.submit "Nachricht senden",
                    class: "inline-flex w-full cursor-pointer items-center justify-center rounded-xl bg-green-600 px-5 py-3 text-base font-medium text-white shadow-sm transition hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-600 focus:ring-offset-2" %>
            </div>
        <% end %>
    </div>
<% end %>