<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="https://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc><%= URI.join(request.base_url, root_path).to_s %></loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc><%= URI.join(request.base_url, unterstuetzer_path).to_s %></loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc><%= URI.join(request.base_url, impressum_path).to_s %></loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
  <url>
    <loc><%= URI.join(request.base_url, datenschutz_path).to_s %></loc>
    <lastmod><%= Date.current.iso8601 %></lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>
</urlset>
